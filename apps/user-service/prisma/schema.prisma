generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  importFileExtension = "ts"
  generatedFileExtension = "ts"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int     @id
  email     String  @unique
  username  String  @unique
}